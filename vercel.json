{
  "regions": ["cdg1"],
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "functions": {
    "src/app/api/bulletins/generate/route.ts": { "maxDuration": 30 },
    "src/app/api/paiements/initier/route.ts": { "maxDuration": 15 },
    "src/app/api/sms/route.ts": { "maxDuration": 15 }
  }
}
